# Stimme Configuration Template
# Copy this file to .env and fill in your values
#
# NOTE: ONNX models are bundled with the application.
# No PyTorch installation or model download env vars are needed.

# REQUIRED: Claude API Key from Anthropic
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# OPTIONAL: Custom Tesseract path (only needed if auto-detection fails)
# Windows example: TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS example: TESSERACT_PATH=/opt/homebrew/bin/tesseract
# Linux example: TESSERACT_PATH=/usr/bin/tesseract
# TESSERACT_PATH=

# OPTIONAL: Custom Poppler path (only needed if auto-detection fails)
# Windows example: POPPLER_PATH=C:\Program Files\poppler\Library\bin
# macOS example: POPPLER_PATH=/opt/homebrew/bin
# Linux example: POPPLER_PATH=/usr/bin
# POPPLER_PATH=

# OPTIONAL: Vector database path (defaults to ./lancedb_vectors)
# VECTOR_DB_PATH=./lancedb_vectors

# OPTIONAL: Debug mode (set to true for verbose logging)
# DEBUG=false